---
import "../styles/admin.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script
      is:inline
      src="https://unpkg.com/lucide@0.511.0/dist/umd/lucide.min.js"
    ></script>
    <meta name="generator" content={Astro.generator} />
    <title>{title} — ZenPanel</title>
  </head>
  <body class="admin-shell">
    <slot />
  </body>
</html>
