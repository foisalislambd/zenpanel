---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Payments">
  <div id="layout-root"></div>
  <div id="page-content" hidden></div>
</AdminLayout>

<script>
  import { mountAdminLayout } from "../../scripts/layout.js";
  import { renderResourcePage } from "../../scripts/resource.js";

  mountAdminLayout({ title: "Payments" });
  renderResourcePage(document.getElementById("page-content"), {
    title: "Payments",
    resourceLabel: "payment",
  });
</script>
