{
  "name": "zenpanel",
  "version": "1.0.0",
  "private": true,
  "description": "ZenPanel — open-source admin UI shell. Scaffold with create-zenpanel.",
  "license": "MIT",
  "author": "Foisal Islam",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Foisalislambd/zenpanel.git"
  },
  "bugs": {
    "url": "https://github.com/Foisalislambd/zenpanel/issues"
